<%- include('../partials/admin-header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="admin-form-card">

      <% if (error) { %>
        <div class="alert alert-danger rounded-3 mb-3">
          <%= error %>
        </div>
      <% } %>

      <form method="POST"
            action="<%= product ? '/admin/products/edit/' + product._id : '/admin/products/add' %>"
            enctype="multipart/form-data">

        <div class="form-section-title">Basic Information</div>

        <div class="row g-3 mb-3">
          <div class="col-12">
            <label class="form-label">Product Name *</label>
            <input type="text"
                   name="name"
                   class="form-control"
                   value="<%= product ? product.name : '' %>"
                   required>
          </div>

          <div class="col-12">
            <label class="form-label">Description *</label>
            <textarea name="description"
                      class="form-control"
                      rows="4"
                      required><%= product ? product.description : '' %></textarea>
          </div>
        </div>

        <div class="form-section-title">Pricing & Inventory</div>

        <div class="row g-3 mb-3">
          <div class="col-md-4">
            <label class="form-label">Price *</label>
            <input type="number"
                   name="price"
                   class="form-control"
                   required>
          </div>

          <div class="col-md-4">
            <label class="form-label">Original Price</label>
            <input type="number"
                   name="originalPrice"
                   class="form-control">
          </div>

          <div class="col-md-4">
            <label class="form-label">Stock *</label>
            <input type="number"
                   name="stock"
                   class="form-control"
                   required>
          </div>
        </div>

        <div class="form-section-title">Category & Brand</div>

        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <label class="form-label">Category *</label>
            <select name="category"
                    class="form-select"
                    required>
              <option value="">Select Category</option>
              <option value="Mobile">Mobile</option>
              <option value="Laptop">Laptop</option>
              <option value="TV">TV</option>
              <option value="Audio">Audio</option>
              <option value="Gaming">Gaming</option>
              <option value="Accessories">Accessories</option>
            </select>
          </div>

          <div class="col-md-6">
            <label class="form-label">Brand *</label>
            <input type="text"
                   name="brand"
                   class="form-control"
                   required>
          </div>
        </div>

        <div class="form-section-title">Product Image</div>

        <div class="row g-3 mb-3">
          <div class="col-12">
            <label class="form-label">Upload Image *</label>
            <input type="file"
                   name="image"
                   class="form-control"
                   required>
          </div>
        </div>

        <div class="col-md-6 mb-4">
          <label class="form-label">SKU *</label>
          <input type="text"
                 name="sku"
                 class="form-control"
                 required>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="checkout-btn">
            Add Product
          </button>

          <a href="/admin/products" class="tm-btn-outline">
            Cancel
          </a>
        </div>

      </form>
    </div>
  </div>
</div>

<%- include('../partials/admin-footer') %>