<%- include('../partials/admin-header') %>
<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="admin-form-card">
      <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger rounded-3 mb-3"><%= error %></div>
<% } %>
      <form method="POST" action="<%= product ? '/admin/products/edit/' + product._id : '/admin/products/add' %>">
        <div class="form-section-title">Basic Information</div>
        <div class="row g-3 mb-3">
          <div class="col-12"><label class="form-label">Product Name *</label><input type="text" name="name" class="form-control" value="<%= product ? product.name : '' %>" required></div>
          <div class="col-12"><label class="form-label">Description *</label><textarea name="description" class="form-control" rows="4" required><%= product ? product.description : '' %></textarea></div>
        </div>
        <div class="form-section-title">Pricing & Inventory</div>
        <div class="row g-3 mb-3">
          <div class="col-md-4"><label class="form-label">Price ($) *</label><input type="number" name="price" class="form-control" step="0.01" min="0" value="<%= product ? product.price : '' %>" required></div>
          <div class="col-md-4"><label class="form-label">Original Price ($)</label><input type="number" name="originalPrice" class="form-control" step="0.01" min="0" value="<%= product ? product.originalPrice : '' %>"></div>
          <div class="col-md-4"><label class="form-label">Stock Quantity *</label><input type="number" name="stock" class="form-control" min="0" value="<%= product ? product.stock : '' %>" required></div>
        </div>
        <div class="form-section-title">Category & Brand</div>
        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <label class="form-label">Category *</label>
            <select name="category" class="form-select" required>
              <option value="">Select Category</option>
              <% ['Mobile','Laptop','TV','Audio','Gaming','Accessories'].forEach(c => { %>
              <option value="<%= c %>" <%= product && product.category===c ? 'selected' : '' %>><%= c %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6"><label class="form-label">Brand *</label><input type="text" name="brand" class="form-control" value="<%= product ? product.brand : '' %>" required></div>
          <div class="col-md-4"><label class="form-label">Rating (0-5)</label><input type="number" name="rating" class="form-control" step="0.1" min="0" max="5" value="<%= product ? product.rating : '0' %>"></div>
        </div>
        <div class="form-section-title">Product Image</div>
        <div class="row g-3 mb-3">
          <div class="col-12">
            <label class="form-label">Upload Image</label>
            <input 
  type="text" 
  name="imageUrl" 
  class="form-control"
  placeholder="products/macbook.jpg"
  required
>
            <% if (product && p.imageUrl) { %>
  <div class="mt-2">
    <img
  src="<%= p.image ? '/images/' + p.image : '/images/placeholder.png' %>"
 id="imgPreview"
      style="max-height:120px;border-radius:8px;object-fit:contain;background:#f8f7ff;padding:8px">
  </div>
<% } else { %>
  <img id="imgPreview" style="display:none;max-height:120px;margin-top:8px;border-radius:8px">
<% } %>
          </div>
        </div>
        <div class="col-md-6">
  <label class="form-label">SKU *</label>
  <input type="text" name="sku" class="form-control" required>
</div>
        <div class="form-section-title">Visibility</div>
        <div class="d-flex gap-4 mb-4">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="isFeatured" id="isFeatured" <%= product && product.isFeatured ? 'checked' : '' %>>
            <label class="form-check-label" for="isFeatured" style="font-size:0.9rem">Featured on Homepage</label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="isTopItem" id="isTopItem" <%= product && product.isTopItem ? 'checked' : '' %>>
            <label class="form-check-label" for="isTopItem" style="font-size:0.9rem">Mark as Top Item</label>
          </div>
        </div>
        <div class="d-flex gap-2">
          <button type="submit" class="checkout-btn" style="font-size:0.9rem;padding:11px"><%= product ? 'Update Product' : 'Add Product' %></button>
          <a href="/admin/products" class="tm-btn-outline" style="padding:11px 24px;font-size:0.9rem">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/admin-footer') %>
