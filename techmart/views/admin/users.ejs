<%- include('../partials/admin-header') %>
<div class="admin-table-card">
  <div class="admin-table-header">
    <div class="admin-table-title">Users (<%= users.length %>)</div>
  </div>
  <div class="table-responsive">
    <table class="table">
      <thead><tr><th>Name</th><th>Email</th><th>Joined</th><th>Role</th></tr></thead>
      <tbody>
        <% if(users.length===0){%><tr><td colspan="4" class="text-center py-4" style="color:var(--text-muted)">No users yet</td></tr><%}%>
        <% users.forEach(u => { %>
        <tr>
          <td><div class="d-flex align-items-center gap-2"><div class="tm-avatar" style="width:32px;height:32px;font-size:0.82rem"><%= u.name.charAt(0).toUpperCase() %></div><strong><%= u.name %></strong></div></td>
          <td style="color:var(--text-muted)"><%= u.email %></td>
          <td style="font-size:0.82rem;color:var(--text-muted)"><%= new Date(u.createdAt).toLocaleDateString() %></td>
          <td><span style="background:#f3f0ff;color:var(--primary);border-radius:50px;padding:2px 10px;font-size:0.78rem;font-weight:600"><%= u.role %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/admin-footer') %>
