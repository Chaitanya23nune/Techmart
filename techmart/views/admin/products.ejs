<%- include('../partials/admin-header') %>

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
  <div class="d-flex gap-2">
    <a href="/admin/products/add" class="tm-btn-primary" style="font-size:0.88rem;padding:8px 20px"><i class="bi bi-plus-lg me-1"></i>Add Product</a>
    <a href="/admin/products/import-api" class="tm-btn-outline" style="font-size:0.88rem;padding:8px 20px"><i class="bi bi-cloud-download me-1"></i>Import from API</a>
  </div>
  <form method="GET" action="/admin/products" class="d-flex gap-2">
    <input type="text" name="search" placeholder="Search products..." class="form-control form-control-sm" style="width:200px" value="<%= filters.search || '' %>">
    <select name="category" class="form-select form-select-sm" style="width:130px">
      <option value="">All Categories</option>
      <% ['Mobile','Laptop','TV','Audio','Gaming','Accessories'].forEach(c => { %>
      <option value="<%= c %>" <%= filters.category===c?'selected':'' %>><%= c %></option>
      <% }) %>
    </select>
    <button type="submit" class="tm-btn-primary" style="font-size:0.85rem;padding:6px 16px">Search</button>
  </form>
</div>

<% if (filters.imported) { %>
<div class="alert alert-success alert-auto rounded-3 mb-3"><i class="bi bi-check-circle me-2"></i>Imported <%= filters.imported %> products from API!</div>
<% } %>

<div class="admin-table-card">
  <div class="admin-table-header">
    <div class="admin-table-title">Products (<%= products.length %>)</div>
  </div>
  <div class="table-responsive">
    <table class="table">
      <thead><tr><th>Image</th><th>Name</th><th>Category</th><th>Price</th><th>Stock</th><th>Featured</th><th>Actions</th></tr></thead>
      <tbody>
        <% if (products.length === 0) { %>
        <tr><td colspan="7" class="text-center py-5" style="color:var(--text-muted)">No products found. <a href="/admin/products/add">Add one</a> or <a href="/admin/products/import-api">import from API</a>.</td></tr>
        <% } %>
        <% products.forEach(p => { %>
        <td>
  <img
    src="<%= p.image || '/images/placeholder.png' %>"
    width="60"
    alt="<%= p.name %>"
    onerror="this.src='/images/placeholder.png'"
    style="width:60px; height:60px; object-fit:cover; border-radius:6px;"
  >
</td>
          <td><div style="font-weight:600;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= p.name %></div><div style="font-size:0.75rem;color:var(--text-muted)"><%= p.brand %></div></td>
          <td><span style="background:#f3f0ff;color:var(--primary);border-radius:50px;padding:2px 10px;font-size:0.78rem;font-weight:600"><%= p.category %></span></td>
          <td><strong>$<%= p.price.toFixed(2) %></strong></td>
          <td><span class="<%= p.stock < 10 ? 'stock-low' : 'stock-ok' %>"><%= p.stock %></span></td>
          <td><% if(p.isFeatured){%><i class="bi bi-star-fill" style="color:var(--accent)"></i><%}else{%><i class="bi bi-star" style="color:var(--text-muted)"></i><%}%></td>
          <td>
            <div class="d-flex gap-1">
              <a href="/admin/products/edit/<%= p._id %>" class="btn-action btn-edit"><i class="bi bi-pencil"></i></a>
              <form action="/admin/products/delete/<%= p._id %>" method="POST" style="display:inline" onsubmit="return confirm('Delete this product?')">
                <button type="submit" class="btn-action btn-del"><i class="bi bi-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/admin-footer') %>
