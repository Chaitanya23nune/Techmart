<%- include('../partials/header') %>
<div class="container-fluid px-4 py-3">
  <h4 style="font-family:'Syne',sans-serif;font-weight:700;margin-bottom:20px"><i class="bi bi-bag me-2"></i>My Cart <span class="text-muted fw-normal" style="font-size:0.85rem;font-family:'DM Sans',sans-serif">(<%= cart.length %> items)</span></h4>
  <% if (cart.length === 0) { %>
  <div class="empty-state">
    <div class="empty-icon">🛒</div>
    <div class="empty-title">Your cart is empty</div>
    <p>Add products to get started</p>
    <a href="/products" class="tm-btn-primary mt-3 d-inline-block">Browse Products</a>
  </div>
  <% } else { %>
  <div class="row g-3">
    <div class="col-lg-8">
      <div class="cart-card">
        <% cart.forEach(item => { %>
        <div class="cart-item"><img
  src="<%= item.image || '/images/placeholder.png' %>"
  alt="<%= item.name %>"
  onerror="this.src='/images/placeholder.png'" style="width:100px; height:100px; object-fit:cover;
>
          <div class="flex-grow-1">
            <div style="font-weight:600;font-size:0.9rem;margin-bottom:4px"><%= item.name %></div>
            <div style="color:var(--primary);font-weight:700">$<%= item.price.toFixed(2) %></div>
          </div>
          <form action="/cart/update" method="POST" class="d-flex align-items-center gap-2">
            <input type="hidden" name="productId" value="<%= item.productId %>">
            <div class="qty-control">
              <button type="submit" name="quantity" value="<%= item.quantity - 1 %>" class="qty-btn">−</button>
              <span class="qty-val"><%= item.quantity %></span>
              <button type="submit" name="quantity" value="<%= item.quantity + 1 %>" class="qty-btn">+</button>
            </div>
          </form>
          <div style="font-weight:700;min-width:70px;text-align:right">$<%= (item.price * item.quantity).toFixed(2) %></div>
          <form action="/cart/remove" method="POST">
            <input type="hidden" name="productId" value="<%= item.productId %>">
            <button type="submit" class="btn-action btn-del"><i class="bi bi-trash"></i></button>
          </form>
        </div>
        <% }) %>
      </div>
      <div class="d-flex justify-content-between mt-2">
        <a href="/products" class="tm-btn-outline"><i class="bi bi-arrow-left me-1"></i>Continue Shopping</a>
        <form action="/cart/clear" method="POST">
          <button type="submit" class="tm-btn-outline" style="color:#dc2626;border-color:#dc2626"><i class="bi bi-trash me-1"></i>Clear Cart</button>
        </form>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="order-summary-card">
        <h6 style="font-family:'Syne',sans-serif;font-weight:700;margin-bottom:16px">Order Summary</h6>
        <% cart.forEach(item => { %>
        <div class="summary-row">
          <span style="color:var(--text-muted);font-size:0.85rem"><%= item.name.substring(0,25) %>... x<%= item.quantity %></span>
          <span>$<%= (item.price * item.quantity).toFixed(2) %></span>
        </div>
        <% }) %>
        <div class="summary-row"><span style="color:var(--text-muted)">Shipping</span><span style="color:var(--accent-green)">Free</span></div>
        <div class="summary-row summary-total"><span>Total</span><span style="color:var(--primary)">$<%= total.toFixed(2) %></span></div>
        <a href="/orders/checkout" class="checkout-btn d-block text-center text-decoration-none">Proceed to Checkout <i class="bi bi-arrow-right ms-1"></i></a>
      </div>
    </div>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
