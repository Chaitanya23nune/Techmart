<%- include('../partials/header') %>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="confirm-card">
        <div class="confirm-icon">✅</div>
        <h2 style="font-family:'Syne',sans-serif;font-weight:700">Order Confirmed!</h2>
        <p style="color:var(--text-muted)">Thank you! Your order has been placed successfully.</p>
        <div class="order-id-badge"># <%= order.orderId %></div>
        <div class="status-stepper mt-4">
          <% const steps = ['Placed','Confirmed','Shipped','Delivered']; %>
          <% const idx = steps.indexOf(order.status); %>
          <% steps.forEach((step, i) => { %>
          <div class="step-item <%= i <= idx ? 'done' : (i === idx+1 ? 'active' : '') %>">
            <div class="step-dot"><% if(i<=idx){%><i class="bi bi-check"></i><%}else{%><%= i+1 %><%}%></div>
            <div class="step-text"><%= step %></div>
          </div>
          <% }) %>
        </div>
        <div class="text-start mt-4" style="background:#f8f7ff;border-radius:12px;padding:16px">
          <div style="font-weight:700;font-size:0.95rem;margin-bottom:10px;font-family:'Syne',sans-serif">Delivery Details</div>
          <p style="font-size:0.88rem;color:var(--text-muted);margin:0"><i class="bi bi-geo-alt me-1"></i><%= order.address.name %>, <%= order.address.street %>, <%= order.address.city %>, <%= order.address.state %> <%= order.address.zip %></p>
          <p style="font-size:0.88rem;color:var(--text-muted);margin-top:6px"><i class="bi bi-telephone me-1"></i><%= order.address.phone %></p>
          <p style="font-size:0.88rem;color:var(--text-muted);margin-top:6px"><i class="bi bi-credit-card me-1"></i><%= order.paymentMethod %></p>
          <p style="font-size:1rem;font-weight:700;color:var(--primary);margin-top:10px">Total: $<%= order.totalAmount.toFixed(2) %></p>
        </div>
        <div class="d-flex gap-3 justify-content-center mt-4">
          <a href="/orders/<%= order._id %>" class="tm-btn-outline">View Order</a>
          <a href="/products" class="tm-btn-primary">Continue Shopping</a>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
