<%- include('../partials/header') %>
<div class="container-fluid px-4 py-3">
  <nav aria-label="breadcrumb" class="breadcrumb-wrap"><ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/orders">My Orders</a></li>
    <li class="breadcrumb-item active">#<%= order.orderId %></li>
  </ol></nav>
  <div class="row g-3">
    <div class="col-lg-8">
      <div class="checkout-card mb-3">
        <div class="d-flex justify-content-between align-items-start mb-4">
          <div>
            <h5 style="font-family:'Syne',sans-serif;font-weight:700">Order #<%= order.orderId %></h5>
            <div style="color:var(--text-muted);font-size:0.85rem">Placed on <%= new Date(order.createdAt).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %></div>
          </div>
          <span class="status-badge status-<%= order.status.toLowerCase() %>" style="font-size:0.85rem;padding:6px 16px"><%= order.status %></span>
        </div>
        <div class="status-stepper mb-4">
          <% const steps=['Placed','Confirmed','Shipped','Delivered']; const idx=steps.indexOf(order.status); %>
          <% steps.forEach((s,i)=>{ %>
          <div class="step-item <%= i<=idx?'done':(i===idx+1?'active':'') %>">
            <div class="step-dot"><% if(i<=idx){%><i class="bi bi-check"></i><%}else{%><%= i+1 %><%}%></div>
            <div class="step-text"><%= s %></div>
          </div>
          <% }) %>
        </div>
        <h6 style="font-weight:700;margin-bottom:12px;font-family:'Syne',sans-serif">Items Ordered</h6>
        <% order.items.forEach(item => { %>
        <div class="d-flex align-items-center gap-3 mb-3 pb-3" style="border-bottom:1px solid var(--border)">
          <img
  src="<%= item.image ? '/images/' + item.image : '/images/placeholder.png' %>"
  style="width:60px;height:60px;object-fit:contain;background:#f8f7ff;border-radius:8px;padding:6px"
>
          <div class="flex-grow-1"><div style="font-weight:600"><%= item.name %></div><div style="color:var(--text-muted);font-size:0.82rem">Qty: <%= item.quantity %></div></div>
          <div style="font-weight:700">$<%= (item.price*item.quantity).toFixed(2) %></div>
        </div>
        <% }) %>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="order-summary-card mb-3">
        <h6 style="font-family:'Syne',sans-serif;font-weight:700;margin-bottom:16px">Delivery Address</h6>
        <p style="font-size:0.88rem;margin:0"><strong><%= order.address.name %></strong><br>
          <%= order.address.phone %><br>
          <%= order.address.street %><br>
          <%= order.address.city %>, <%= order.address.state %> <%= order.address.zip %>
        </p>
      </div>
      <div class="order-summary-card">
        <h6 style="font-family:'Syne',sans-serif;font-weight:700;margin-bottom:12px">Payment</h6>
        <div class="summary-row"><span>Method</span><span><%= order.paymentMethod %></span></div>
        <div class="summary-row"><span>Delivery</span><span style="color:var(--accent-green)">Free</span></div>
        <div class="summary-row summary-total"><span>Total</span><span style="color:var(--primary)">$<%= order.totalAmount.toFixed(2) %></span></div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
