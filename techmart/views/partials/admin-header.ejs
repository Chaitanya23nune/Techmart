<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | TechMart Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="admin-body">

<div class="admin-wrapper">
  <!-- Sidebar -->
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
      <span class="logo-box">TM</span>
      <span class="logo-text">TechMart</span>
      <button class="sidebar-close d-lg-none" onclick="toggleSidebar()"><i class="bi bi-x-lg"></i></button>
    </div>
    <div class="sidebar-divider"></div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="sidebar-link <%= title.includes('Dashboard') ? 'active' : '' %>">
        <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
      </a>
      <a href="/admin/products" class="sidebar-link <%= title.includes('Product') ? 'active' : '' %>">
        <i class="bi bi-box-seam-fill"></i><span>Products</span>
      </a>
      <a href="/admin/orders" class="sidebar-link <%= title.includes('Order') ? 'active' : '' %>">
        <i class="bi bi-receipt-cutoff"></i><span>Orders</span>
      </a>
      <a href="/admin/users" class="sidebar-link <%= title.includes('User') ? 'active' : '' %>">
        <i class="bi bi-people-fill"></i><span>Users</span>
      </a>
    </nav>
    <div class="sidebar-bottom">
      <a href="/" class="sidebar-link"><i class="bi bi-shop"></i><span>View Store</span></a>
      <a href="/auth/logout" class="sidebar-link text-danger-link"><i class="bi bi-box-arrow-left"></i><span>Logout</span></a>
    </div>
  </aside>

  <div class="admin-main">
    <!-- Top Bar -->
    <header class="admin-topbar">
      <button class="sidebar-toggle d-lg-none" onclick="toggleSidebar()">
        <i class="bi bi-list"></i>
      </button>
      <div class="admin-page-title"><%= title %></div>
      <div class="admin-user-info ms-auto">
        <div class="tm-avatar">
  <%= user?.name ? user.name.charAt(0).toUpperCase() : 'A' %>
</div>
        <span class="d-none d-md-inline">
  <%= user?.name || 'Admin' %>
</span>
      </div>
    </header>

    <div class="admin-content">
