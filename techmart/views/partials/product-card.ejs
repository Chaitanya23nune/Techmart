<div class="product-card">
  <% if (product.isTopItem) { %>
    <div class="product-badge badge-top">Top Item</div>
  <% } %>
  <a href="/cart" class="product-fav" title="Add to Favourites"><i class="bi bi-heart"></i></a>
  <a href="/products/<%= product._id %>" class="product-img-wrap">
    <img
  src="<%= product.image ? '/' + product.image : '/images/placeholder.png' %>"
  alt="<%= product.name %>"
  class="product-img"
  onerror="this.src='/images/placeholder.png'">
  </a>
  <div class="product-info">
    <div class="product-category"><%= product.category %></div>
    <a href="/products/<%= product._id %>" class="product-name"><%= product.name.length > 45 ? product.name.substring(0,45) + '...' : product.name %></a>
    <div class="product-rating">
      <% for(let i=1;i<=5;i++) { %>
        <i class="bi bi-star<%= i <= Math.round(product.rating) ? '-fill' : '' %> <%= i <= Math.round(product.rating) ? 'text-warning' : 'text-muted' %>"></i>
      <% } %>
      <span class="rating-count">(<%= product.reviewCount || 0 %>)</span>
    </div>
    <div class="product-price-row">
      <% if (product.originalPrice && product.originalPrice > product.price) { %>
        <span class="price-original">$<%= product.originalPrice.toFixed(2) %></span>
      <% } %>
      <span class="price-current">
        <i class="bi bi-bag2"></i> $<%= product.price.toFixed(2) %>
      </span>
    </div>
    <button class="tm-btn-primary w-100 mt-2 btn-add-cart"
      data-id="<%= product._id %>"
      data-name="<%= product.name %>">
      <i class="bi bi-bag-plus me-1"></i> Add to Cart
    </button>
  </div>
</div>
